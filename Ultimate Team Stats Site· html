<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hunter Ranking System</title>

<style>
/* ===== GLOBAL ===== */
body {
  margin:0;
  font-family: 'Segoe UI', system-ui, sans-serif;
  background:
    radial-gradient(circle at 20% 10%, #1a0033 0%, transparent 40%),
    radial-gradient(circle at 80% 90%, #001a33 0%, transparent 40%),
    #020204;
  color:white;
  overflow-x:hidden;
}

/* floating particles */
body::before {
  content:"";
  position:fixed;
  inset:0;
  background-image:
    radial-gradient(2px 2px at 20% 30%, rgba(255,255,255,.15), transparent),
    radial-gradient(2px 2px at 70% 60%, rgba(0,170,255,.2), transparent);
  animation: floatBg 20s linear infinite;
  pointer-events:none;
}

@keyframes floatBg {
  from { transform: translateY(0); }
  to { transform: translateY(-200px); }
}

/* ===== HERO ===== */
.hero {
  text-align:center;
  padding:70px 20px 40px;
}

.hero h1 {
  font-size:3.2rem;
  letter-spacing:2px;
  background:linear-gradient(90deg,#7c3aed,#22d3ee);
  -webkit-background-clip:text;
  background-clip:text;
  color:transparent;
  text-shadow:0 0 25px rgba(124,58,237,.6);
  animation: glowPulse 3s infinite alternate;
}

@keyframes glowPulse {
  from { text-shadow:0 0 10px rgba(124,58,237,.4); }
  to { text-shadow:0 0 35px rgba(34,211,238,.9); }
}

.hero p {
  opacity:.8;
}

/* ===== TOP CARDS ===== */
.top-section {
  padding:20px;
  text-align:center;
}

.top-grid {
  display:flex;
  flex-wrap:wrap;
  justify-content:center;
  gap:20px;
  margin-top:25px;
}

.card {
  width:190px;
  padding:18px;
  border-radius:18px;
  background:linear-gradient(145deg,#0a0a12,#050507);
  border:1px solid rgba(124,58,237,.4);
  position:relative;
  overflow:hidden;
  transition:.25s;
}

.card::before {
  content:"";
  position:absolute;
  inset:-2px;
  background:linear-gradient(120deg,transparent,rgba(124,58,237,.5),transparent);
  opacity:0;
  transition:.3s;
}

.card:hover::before { opacity:1; }

.card:hover {
  transform:translateY(-6px) scale(1.05);
  box-shadow:0 0 30px rgba(124,58,237,.5);
}

.rank-big {
  font-size:1.4rem;
  color:#22d3ee;
}

/* ===== TABLE ===== */
.board {
  max-width:1100px;
  margin:auto;
  padding:40px 20px 80px;
}

.search {
  width:100%;
  padding:12px;
  border-radius:12px;
  border:1px solid rgba(255,255,255,.1);
  background:#07070c;
  color:white;
  margin-bottom:20px;
}

table {
  width:100%;
  border-collapse:collapse;
  background:rgba(10,10,20,.6);
  backdrop-filter:blur(6px);
  border-radius:12px;
  overflow:hidden;
}

th, td {
  padding:12px;
  text-align:center;
  border-bottom:1px solid rgba(255,255,255,.08);
}

th {
  background:rgba(124,58,237,.2);
}

/* ===== TIERS ===== */
.badge {
  padding:4px 10px;
  border-radius:999px;
  font-weight:bold;
  font-size:.8rem;
}

.s { background:#ff3b3b; box-shadow:0 0 10px #ff3b3b; }
.a { background:#7c3aed; }
.b { background:#3b82f6; }
.c { background:#555; }

/* ===== SPECIAL PLAYER HIGHLIGHT ===== */
tr.me {
  background:rgba(34,211,238,.12);
  box-shadow:inset 0 0 15px rgba(34,211,238,.4);
}
</style>
</head>

<body>

<header class="hero">
  <h1>⚔️ HUNTER RANKING SYSTEM</h1>
  <p>2000 combattants analysés — seuls les élites dominent</p>
</header>

<section class="top-section">
  <h2>🔥 ÉLITE MONDIALE</h2>
  <div class="top-grid" id="topGrid"></div>
</section>

<section class="board">
  <h2>📊 Classement complet</h2>
  <input class="search" id="search" placeholder="Scanner un hunter...">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Hunter</th>
        <th>Skill</th>
        <th>Speed</th>
        <th>IQ</th>
        <th>Tier</th>
      </tr>
    </thead>
    <tbody id="tbody"></tbody>
  </table>
</section>

<script>
// ===== PLAYERS =====
const players = [];

// positions demandées
players.push(
  {rank:10,name:"Kenni",skill:98,speed:96,iq:97},
  {rank:15,name:"Sonya",skill:95,speed:93,iq:94},
  {rank:20,name:"Louis",skill:92,speed:91,iq:90},
  {rank:30,name:"Clara",skill:89,speed:88,iq:91}
);

// generate others
const baseNames=["Shadow","Abyss","Nova","Phantom","Vortex","Ragnar","Zero","Blaze","Onyx","Drift"];

function rand(min,max){return Math.floor(Math.random()*(max-min))+min}

for(let i=1;i<=2000;i++){
  if([10,15,20,30].includes(i)) continue;
  players.push({
    rank:i,
    name:baseNames[rand(0,baseNames.length)] + "_" + i,
    skill:rand(40,90),
    speed:rand(40,90),
    iq:rand(40,90)
  });
}

players.sort((a,b)=>a.rank-b.rank);

// ===== TIER =====
function tier(p){
  const avg=(p.skill+p.speed+p.iq)/3;
  if(avg>=95) return 'S';
  if(avg>=90) return 'A';
  if(avg>=75) return 'B';
  return 'C';
}

function tierClass(t){return t.toLowerCase();}

// ===== TOP =====
const topGrid=document.getElementById('topGrid');
players.slice(0,10).forEach(p=>{
  const d=document.createElement('div');
  d.className='card';
  d.innerHTML=`
    <div class="rank-big">#${p.rank}</div>
    <h3>${p.name}</h3>
    <p>⚡ ${p.skill} | 🌀 ${p.speed} | 🧠 ${p.iq}</p>
  `;
  topGrid.appendChild(d);
});

// ===== TABLE =====
const tbody=document.getElementById('tbody');

function render(list){
  tbody.innerHTML='';
  list.slice(0,300).forEach(p=>{
    const t=tier(p);
    const tr=document.createElement('tr');
    if(p.name==='Kenni') tr.classList.add('me');

    tr.innerHTML=`
      <td>${p.rank}</td>
      <td>${p.name}</td>
      <td>${p.skill}</td>
      <td>${p.speed}</td>
      <td>${p.iq}</td>
      <td><span class="badge ${tierClass(t)}">${t}</span></td>
    `;
    tbody.appendChild(tr);
  });
}

render(players);

// ===== SEARCH =====
document.getElementById('search').addEventListener('input',e=>{
  const v=e.target.value.toLowerCase();
  render(players.filter(p=>p.name.toLowerCase().includes(v)));
});
</script>

</body>
</html>
